# CortexBridge — minimal self-host environment.
# Copy to `.env`, fill in, then:
#   docker compose -f docker-compose.selfhost.yml up -d --build
# NEVER commit .env.

# ---- Host paths -------------------------------------------------------------
# Where your projects live. The bridge only sees projects under this directory.
CORTEX_WORKSPACE=/home/youruser/workspace
# Claude Code's config dir (credentials + JSONL transcripts).
CORTEX_CLAUDE_DIR=/home/youruser/.claude
# Bridge's own SQLite state. Keep it OUT of your workspace. Create it first:
#   sudo mkdir -p /opt/cortex/data/sqlite && sudo chown -R $USER: /opt/cortex/data
CORTEX_DATA_DIR=/opt/cortex/data/sqlite

# Your uid, used to find the host tmux socket at /tmp/tmux-<uid>.
# MUST be 1000 — the container's `cortex` user is uid 1000 and the socket is
# only readable by its owner. Verify with: id -u
CORTEX_UID=1000

# ---- Network ----------------------------------------------------------------
# Which host IP the bridge binds to.
#   127.0.0.1        → localhost only (default; use an SSH tunnel to reach it)
#   192.168.x.y      → reachable from your LAN
#   100.x.y.z        → reachable over your VPN (Netbird / Tailscale)
# Do NOT set this to a public IP or 0.0.0.0 on an internet-facing host.
BRIDGE_BIND_IP=127.0.0.1

# The origin your phone loads the PWA from. Hooks build push click-through URLs
# from this, so it must be what the browser actually sees.
#   http://192.168.1.50:3000        → LAN, no push (iOS needs a public CA)
#   https://cortex.example.com      → via Cloudflare Tunnel / reverse proxy
BRIDGE_PUBLIC_URL=http://192.168.1.50:3000

# ---- Auth -------------------------------------------------------------------
# Used only to mint device bearer tokens via POST /api/auth/issue.
# Generate: openssl rand -hex 32
BRIDGE_ADMIN_SECRET=change-me

# ---- Web Push (VAPID) -------------------------------------------------------
# Generate once: npx --yes web-push generate-vapid-keys
# Required even if you don't use push — the bridge refuses to start without them.
# The private key never leaves the container; the public one is served from
# GET /api/push/vapid-key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Cloudflare Tunnel (optional, only for `--profile tunnel`) --------------
# Needed only if you want Web Push on iOS, which requires a publicly-trusted
# cert. Token from CF Zero Trust → Networks → Tunnels.
# Route the tunnel's Public Hostname → http://cc-bridge:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# ---- CortexPlexus MCP (optional) --------------------------------------------
# Only if you run the author's code-intelligence MCP server. Empty = feature off.
CORTEXPLEXUS_MCP_URL=
