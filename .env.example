# CortexBridge — environment variables
# Copy to .env and fill in. NEVER commit .env to git.

# ---- Bridge API ----
# Admin secret for issuing bearer tokens. Long random string.
BRIDGE_ADMIN_SECRET=change-me-to-a-32-byte-random-string

# BRIDGE_HOOK_TOKEN is generated by the bridge process at startup
# and written to /run/bridge-hook-token (mode 0600). Not configurable here.

# ---- Caddy / Network ----
# Hostname accessible inside Netbird (default is the auto-managed peer FQDN)
BRIDGE_HOSTNAME=cortex-host.vpn.example
# Netbird IP of this host (run `ip addr show wt0` to find it)
BRIDGE_NETBIRD_IP=100.0.0.0
# Public origin PWA is served from — used by hooks to build push click URLs.
# For mobile/Web Push compatibility, this should be the publicly-trusted CF Tunnel
# hostname, NOT the Netbird FQDN (iOS Web Push requires public CA per ADR-012).
BRIDGE_PUBLIC_URL=https://your-pwa-host.example.com

# ---- Cloudflare Tunnel ----
# Token from CF Zero Trust → Networks → Tunnels → Create/Edit tunnel.
# Routes a Public Hostname (configured in dashboard) → cc-bridge:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# ---- Web Push (VAPID) ----
# Generate once via `npx web-push generate-vapid-keys`. Public key is exposed via
# GET /api/push/vapid-key. Private key NEVER leaves the bridge container.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@cortexbridge.local

# ---- CortexPlexus MCP (optional, ADR-025) ----
# LAN address of your cortexplexus MCP server. Empty = memory cockpit degrades.
CORTEXPLEXUS_MCP_URL=
